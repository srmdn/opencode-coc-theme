{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "cocGold": "#eec941",
    "cocGoldDark": "#bc8c1c",
    "cocGoldLight": "#f2d46c",
    "cocElixirPink": "#FF05E2",
    "cocElixirPinkDark": "#C404B2",
    "cocElixirBlue": "#80b7f7",
    "cocElixirBlueDark": "#5A9DE0",
    "cocGrassGreen": "#6eac51",
    "cocGrassGreenDark": "#4F7D3A",
    "cocSteelBlue": "#597aa2",
    "cocParchment": "#dcccc0",
    "cocParchmentMuted": "#8B7D6B",
    "cocBgDark": "#2D1A0E",
    "cocBgPanel": "#3D2A18",
    "cocBgElement": "#4A3520",
    "cocBorderGold": "#bc8c1c",
    "cocDamageRed": "#E53935",
    "cocDarkUI": "#374357",
    "cocDarkWood": "#4c4429"
  },
  "theme": {
    "primary": {"dark": "cocGold", "light": "cocGoldDark"},
    "secondary": {"dark": "cocElixirPink", "light": "cocElixirPinkDark"},
    "accent": {"dark": "cocElixirBlue", "light": "cocElixirBlueDark"},
    "error": {"dark": "cocDamageRed", "light": "cocDamageRed"},
    "warning": {"dark": "cocGoldLight", "light": "cocGoldDark"},
    "success": {"dark": "cocGrassGreen", "light": "cocGrassGreenDark"},
    "info": {"dark": "cocSteelBlue", "light": "cocSteelBlue"},
    "text": {"dark": "cocParchment", "light": "cocBgDark"},
    "textMuted": {"dark": "cocParchmentMuted", "light": "cocParchmentMuted"},
    "background": {"dark": "cocBgDark", "light": "cocParchment"},
    "backgroundPanel": {"dark": "cocBgPanel", "light": "#E8D5A3"},
    "backgroundElement": {"dark": "cocBgElement", "light": "#D4C08A"},
    "border": {"dark": "cocBorderGold", "light": "cocBorderGold"},
    "borderActive": {"dark": "cocGold", "light": "cocGoldDark"},
    "borderSubtle": {"dark": "cocBgElement", "light": "#D4C08A"},
    "diffAdded": {"dark": "cocGrassGreen", "light": "cocGrassGreenDark"},
    "diffRemoved": {"dark": "cocDamageRed", "light": "cocDamageRed"},
    "diffContext": {"dark": "cocDarkUI", "light": "#C8B880"},
    "diffHunkHeader": {"dark": "cocSteelBlue", "light": "cocSteelBlue"},
    "diffHighlightAdded": {"dark": "cocGrassGreen", "light": "cocGrassGreenDark"},
    "diffHighlightRemoved": {"dark": "cocDamageRed", "light": "cocDamageRed"},
    "diffAddedBg": {"dark": "#1B3A1B", "light": "#D4EDDA"},
    "diffRemovedBg": {"dark": "#3A1B1B", "light": "#F8D7DA"},
    "diffContextBg": {"dark": "cocBgPanel", "light": "#E8D5A3"},
    "diffLineNumber": {"dark": "cocParchmentMuted", "light": "cocParchmentMuted"},
    "diffAddedLineNumberBg": {"dark": "#1B3A1B", "light": "#C3E6CB"},
    "diffRemovedLineNumberBg": {"dark": "#3A1B1B", "light": "#F5C6CB"},
    "markdownText": {"dark": "cocParchment", "light": "cocBgDark"},
    "markdownHeading": {"dark": "cocGold", "light": "cocGoldDark"},
    "markdownLink": {"dark": "cocElixirBlue", "light": "cocElixirBlueDark"},
    "markdownLinkText": {"dark": "cocElixirPink", "light": "cocElixirPinkDark"},
    "markdownCode": {"dark": "cocGrassGreen", "light": "cocGrassGreenDark"},
    "markdownBlockQuote": {"dark": "cocBorderGold", "light": "cocBorderGold"},
    "markdownEmph": {"dark": "cocGoldLight", "light": "cocGoldDark"},
    "markdownStrong": {"dark": "cocGold", "light": "cocGoldDark"},
    "markdownHorizontalRule": {"dark": "cocBorderGold", "light": "cocBorderGold"},
    "markdownListItem": {"dark": "cocGold", "light": "cocGoldDark"},
    "markdownListEnumeration": {"dark": "cocElixirPink", "light": "cocElixirPinkDark"},
    "markdownImage": {"dark": "cocElixirBlue", "light": "cocElixirBlueDark"},
    "markdownImageText": {"dark": "cocElixirPink", "light": "cocElixirPinkDark"},
    "markdownCodeBlock": {"dark": "cocParchment", "light": "cocBgDark"},
    "syntaxComment": {"dark": "cocParchmentMuted", "light": "cocParchmentMuted"},
    "syntaxKeyword": {"dark": "cocGold", "light": "cocGoldDark"},
    "syntaxFunction": {"dark": "cocElixirPink", "light": "cocElixirPinkDark"},
    "syntaxVariable": {"dark": "cocParchment", "light": "cocBgDark"},
    "syntaxString": {"dark": "cocGrassGreen", "light": "cocGrassGreenDark"},
    "syntaxNumber": {"dark": "cocElixirBlue", "light": "cocElixirBlueDark"},
    "syntaxType": {"dark": "cocSteelBlue", "light": "cocSteelBlue"},
    "syntaxOperator": {"dark": "cocGoldLight", "light": "cocGoldDark"},
    "syntaxPunctuation": {"dark": "cocParchmentMuted", "light": "cocParchmentMuted"}
  }
}
