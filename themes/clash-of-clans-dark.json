{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "storeBeige": "#D8C4AD",
    "storeBeigeLight": "#F5E3C7",
    "storeWhite": "#FFFFFF",
    "storeText": "#191919",
    "storeTextMuted": "#666666",
    "storeBlue": "#2D85F3",
    "storeBlueBright": "#4A9EFF",
    "storeGold": "#F2CD4A",
    "storeGoldDark": "#BC8C1C",
    "storeGreen": "#46DFAE",
    "storeGreenDark": "#2F9D74",
    "storeRed": "#F94343",
    "storeInk": "#15161E",
    "storeInkPanel": "#1B1B22",
    "storeInkElevated": "#21222C",
    "storeInkBorder": "#2D2E3A",
    "storeBorderLight": "#E3E3E3",
    "storeBorder": "#DDDDDD",
    "storeBorderDark": "#313345"
  },
  "theme": {
    "primary": {"dark": "storeBlue", "light": "storeBlueBright"},
    "secondary": {"dark": "storeGold", "light": "storeGoldDark"},
    "accent": {"dark": "storeBeigeLight", "light": "storeBeige"},
    "error": {"dark": "storeRed", "light": "storeRed"},
    "warning": {"dark": "storeGold", "light": "storeGoldDark"},
    "success": {"dark": "storeGreen", "light": "storeGreenDark"},
    "info": {"dark": "storeBlueBright", "light": "storeBlue"},
    "text": {"dark": "storeBeigeLight", "light": "storeText"},
    "textMuted": {"dark": "#B8B8B8", "light": "storeTextMuted"},
    "background": {"dark": "storeInk", "light": "storeBeige"},
    "backgroundPanel": {"dark": "storeInkPanel", "light": "storeWhite"},
    "backgroundElement": {"dark": "storeInkElevated", "light": "storeWhite"},
    "border": {"dark": "storeBorderDark", "light": "storeBorder"},
    "borderActive": {"dark": "storeBlueBright", "light": "storeBlue"},
    "borderSubtle": {"dark": "storeInkBorder", "light": "storeBorderLight"},
    "diffAdded": {"dark": "storeGreen", "light": "storeGreenDark"},
    "diffRemoved": {"dark": "storeRed", "light": "storeRed"},
    "diffContext": {"dark": "storeInkBorder", "light": "storeBeigeLight"},
    "diffHunkHeader": {"dark": "storeBlueBright", "light": "storeBlue"},
    "diffHighlightAdded": {"dark": "storeGreen", "light": "storeGreenDark"},
    "diffHighlightRemoved": {"dark": "storeRed", "light": "storeRed"},
    "diffAddedBg": {"dark": "#1B3A1B", "light": "#D4EDDA"},
    "diffRemovedBg": {"dark": "#3A1B1B", "light": "#F8D7DA"},
    "diffContextBg": {"dark": "storeInkPanel", "light": "storeBeigeLight"},
    "diffLineNumber": {"dark": "storeTextMuted", "light": "storeTextMuted"},
    "diffAddedLineNumberBg": {"dark": "#1B3A1B", "light": "#C3E6CB"},
    "diffRemovedLineNumberBg": {"dark": "#3A1B1B", "light": "#F5C6CB"},
    "markdownText": {"dark": "storeBeigeLight", "light": "storeText"},
    "markdownHeading": {"dark": "storeBlue", "light": "storeBlueBright"},
    "markdownLink": {"dark": "storeBlueBright", "light": "storeBlue"},
    "markdownLinkText": {"dark": "storeBlueBright", "light": "storeBlue"},
    "markdownCode": {"dark": "storeGreen", "light": "storeGreenDark"},
    "markdownBlockQuote": {"dark": "storeGold", "light": "storeGoldDark"},
    "markdownEmph": {"dark": "storeGold", "light": "storeGoldDark"},
    "markdownStrong": {"dark": "storeBlue", "light": "storeBlueBright"},
    "markdownHorizontalRule": {"dark": "storeBorderDark", "light": "storeBorder"},
    "markdownListItem": {"dark": "storeBlue", "light": "storeBlueBright"},
    "markdownListEnumeration": {"dark": "storeGold", "light": "storeGoldDark"},
    "markdownImage": {"dark": "storeBlueBright", "light": "storeBlue"},
    "markdownImageText": {"dark": "storeBlueBright", "light": "storeBlue"},
    "markdownCodeBlock": {"dark": "storeBeigeLight", "light": "storeText"},
    "syntaxComment": {"dark": "storeTextMuted", "light": "storeTextMuted"},
    "syntaxKeyword": {"dark": "storeBlue", "light": "storeBlueBright"},
    "syntaxFunction": {"dark": "storeGold", "light": "storeGoldDark"},
    "syntaxVariable": {"dark": "storeBeigeLight", "light": "storeText"},
    "syntaxString": {"dark": "storeGreen", "light": "storeGreenDark"},
    "syntaxNumber": {"dark": "storeGoldDark", "light": "storeGold"},
    "syntaxType": {"dark": "storeBlueBright", "light": "storeBlue"},
    "syntaxOperator": {"dark": "storeGold", "light": "storeGoldDark"},
    "syntaxPunctuation": {"dark": "storeTextMuted", "light": "storeTextMuted"}
  }
}
