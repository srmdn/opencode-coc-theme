{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "woodCream": "#E8C8A3",
    "creamLight": "#F5E3C7",
    "textBlack": "#111111",
    "textGray": "#555555",
    "cardWhite": "#FFFFFF",
    "shieldRed": "#D71916",
    "maroonDark": "#8F1C12",
    "goldTrim": "#D8A441",
    "goldHighlight": "#F4C95D",
    "woodBrown": "#A66A3A",
    "woodDark": "#5A3322",
    "storeBlue": "#1779FF",
    "footerBlack": "#000000",
    "footerGray": "#B8B8B8",
    "grassGreen": "#6eac51",
    "grassGreenDark": "#4F7D3A"
  },
  "theme": {
    "primary": {"dark": "goldTrim", "light": "goldTrim"},
    "secondary": {"dark": "shieldRed", "light": "maroonDark"},
    "accent": {"dark": "woodBrown", "light": "woodDark"},
    "error": {"dark": "shieldRed", "light": "maroonDark"},
    "warning": {"dark": "goldHighlight", "light": "goldTrim"},
    "success": {"dark": "grassGreen", "light": "grassGreenDark"},
    "info": {"dark": "storeBlue", "light": "storeBlue"},
    "text": {"dark": "textBlack", "light": "textBlack"},
    "textMuted": {"dark": "textGray", "light": "textGray"},
    "background": {"dark": "woodCream", "light": "woodCream"},
    "backgroundPanel": {"dark": "creamLight", "light": "creamLight"},
    "backgroundElement": {"dark": "cardWhite", "light": "cardWhite"},
    "border": {"dark": "goldTrim", "light": "goldTrim"},
    "borderActive": {"dark": "goldHighlight", "light": "goldHighlight"},
    "borderSubtle": {"dark": "woodCream", "light": "woodCream"},
    "diffAdded": {"dark": "grassGreen", "light": "grassGreenDark"},
    "diffRemoved": {"dark": "shieldRed", "light": "maroonDark"},
    "diffContext": {"dark": "#D4C08A", "light": "#C8B880"},
    "diffHunkHeader": {"dark": "storeBlue", "light": "storeBlue"},
    "diffHighlightAdded": {"dark": "grassGreen", "light": "grassGreenDark"},
    "diffHighlightRemoved": {"dark": "shieldRed", "light": "maroonDark"},
    "diffAddedBg": {"dark": "#D4EDDA", "light": "#D4EDDA"},
    "diffRemovedBg": {"dark": "#F8D7DA", "light": "#F8D7DA"},
    "diffContextBg": {"dark": "creamLight", "light": "creamLight"},
    "diffLineNumber": {"dark": "footerGray", "light": "footerGray"},
    "diffAddedLineNumberBg": {"dark": "#C3E6CB", "light": "#C3E6CB"},
    "diffRemovedLineNumberBg": {"dark": "#F5C6CB", "light": "#F5C6CB"},
    "markdownText": {"dark": "textBlack", "light": "textBlack"},
    "markdownHeading": {"dark": "maroonDark", "light": "maroonDark"},
    "markdownLink": {"dark": "storeBlue", "light": "storeBlue"},
    "markdownLinkText": {"dark": "storeBlue", "light": "storeBlue"},
    "markdownCode": {"dark": "grassGreen", "light": "grassGreenDark"},
    "markdownBlockQuote": {"dark": "goldTrim", "light": "goldTrim"},
    "markdownEmph": {"dark": "woodBrown", "light": "woodDark"},
    "markdownStrong": {"dark": "maroonDark", "light": "maroonDark"},
    "markdownHorizontalRule": {"dark": "goldTrim", "light": "goldTrim"},
    "markdownListItem": {"dark": "goldTrim", "light": "goldTrim"},
    "markdownListEnumeration": {"dark": "shieldRed", "light": "maroonDark"},
    "markdownImage": {"dark": "storeBlue", "light": "storeBlue"},
    "markdownImageText": {"dark": "storeBlue", "light": "storeBlue"},
    "markdownCodeBlock": {"dark": "textBlack", "light": "textBlack"},
    "syntaxComment": {"dark": "footerGray", "light": "footerGray"},
    "syntaxKeyword": {"dark": "maroonDark", "light": "maroonDark"},
    "syntaxFunction": {"dark": "shieldRed", "light": "maroonDark"},
    "syntaxVariable": {"dark": "textBlack", "light": "textBlack"},
    "syntaxString": {"dark": "grassGreen", "light": "grassGreenDark"},
    "syntaxNumber": {"dark": "woodBrown", "light": "woodDark"},
    "syntaxType": {"dark": "storeBlue", "light": "storeBlue"},
    "syntaxOperator": {"dark": "goldTrim", "light": "goldTrim"},
    "syntaxPunctuation": {"dark": "textGray", "light": "textGray"}
  }
}
